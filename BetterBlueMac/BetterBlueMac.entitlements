<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox is enabled by default on macOS apps. We need network and
	     user-selected file access so the existing main app code paths
	     (HTTP API, debug export sheet) work. -->
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<key>com.apple.security.files.user-selected.read-only</key>
	<true/>

	<!-- Same iCloud container as the iOS target so SwiftData / CloudKit
	     sync the same store across iPhone and Mac. -->
	<key>com.apple.developer.icloud-container-identifiers</key>
	<array>
		<string>iCloud.com.markschmidt.BetterBlue</string>
	</array>
	<key>com.apple.developer.icloud-services</key>
	<array>
		<string>CloudKit</string>
	</array>
	<key>com.apple.developer.ubiquity-kvstore-identifier</key>
	<string>$(TeamIdentifierPrefix)$(CFBundleIdentifier)</string>

	<!-- Same App Group as the iOS target / widgets so the
	     `group.com.betterblue.shared` UserDefaults suite resolves. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.betterblue.shared</string>
	</array>
</dict>
</plist>
